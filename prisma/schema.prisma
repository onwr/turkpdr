generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
  AUTHOR
  MEMBER
}

enum UserStatus {
  ACTIVE
  PASSIVE
  BANNED
}

enum ContentType {
  NEWS
  ARTICLE
  GUIDE
  METAPHOR
  PSIKO_SANAT
  VIDEO
  FILE
}

enum ContentStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  REVISION_REQUESTED
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  password       String?
  avatar         String?
  coverImage     String?
  title          String?
  bio            String?
  phone          String?
  city           String?
  website        String?
  workAreas      String[]   @default([])
  expertiseAreas String[]   @default([])
  role           UserRole   @default(MEMBER)
  status         UserStatus @default(ACTIVE)

  contents                  Content[]
  comments                  Comment[]
  likes                     Like[]
  favorites                 Favorite[]
  files                     FileAsset[]
  mediaAssets               MediaAsset[]
  sentMessages              Message[]                  @relation("SentMessages")
  receivedMessages          Message[]                  @relation("ReceivedMessages")
  conversationStates        MessageConversationState[] @relation("ConversationStateUser")
  partnerConversationStates MessageConversationState[] @relation("ConversationStatePartner")
  testResults               TestResult[]
  activityLogs              ActivityLog[]
  notifications             Notification[]
  reviewedContents          Content[]                  @relation("ReviewedContents")
  assignedContents          Content[]                  @relation("AssignedContents")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   String      @id @default(cuid())
  name String
  slug String      @unique
  type ContentType

  contents Content[]
  tests    Test[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Content {
  id         String        @id @default(cuid())
  title      String
  slug       String        @unique
  summary    String?
  content    String?
  coverImage String?
  type       ContentType
  status     ContentStatus @default(DRAFT)
  featured   Boolean       @default(false)
  views      Int           @default(0)

  seoTitle       String?
  seoDescription String?
  ogImage        String?
  canonicalUrl   String?
  noIndex        Boolean @default(false)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  tags      ContentTag[]
  comments  Comment[]
  likes     Like[]
  favorites Favorite[]

  reviewNote       String?
  reviewedById     String?
  reviewedBy       User?     @relation("ReviewedContents", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  assignedEditorId String?
  assignedEditor   User?     @relation("AssignedContents", fields: [assignedEditorId], references: [id])

  publishedAt DateTime?
  scheduledAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([scheduledAt])
  @@index([deletedAt])
  @@index([assignedEditorId])
  @@index([status])
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique

  contents ContentTag[]

  createdAt DateTime @default(now())
}

model ContentTag {
  contentId String
  tagId     String

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
}

model Comment {
  id      String @id @default(cuid())
  content String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  postId String
  post   Content @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Like {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  postId String
  post   Content @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Favorite {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  postId String
  post   Content @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model FileAsset {
  id          String        @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  fileType    String?
  fileSize    Int?
  downloads   Int           @default(0)
  status      ContentStatus @default(PENDING)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

model Test {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String?
  image         String?
  duration      String?
  questionCount Int?
  iframeUrl     String?
  status        ContentStatus @default(PUBLISHED)

  seoTitle       String?
  seoDescription String?
  ogImage        String?
  canonicalUrl   String?
  noIndex        Boolean @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  questions TestQuestion[]
  results   TestResult[]

  scheduledAt DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledAt])
  @@index([deletedAt])
}

model TestQuestion {
  id        String @id @default(cuid())
  text      String
  sortOrder Int    @default(0)

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  options TestOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestOption {
  id        String @id @default(cuid())
  text      String
  score     Int    @default(0)
  sortOrder Int    @default(0)

  questionId String
  question   TestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model TestResult {
  id                String  @id @default(cuid())
  totalScore        Int
  maxScore          Int
  resultLabel       String
  resultDescription String?
  answers           Json

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Poll {
  id       String        @id @default(cuid())
  question String
  status   ContentStatus @default(PUBLISHED)

  options PollOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PollOption {
  id    String @id @default(cuid())
  text  String
  votes Int    @default(0)

  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
}

model Message {
  id      String  @id @default(cuid())
  message String
  isRead  Boolean @default(false)

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, isRead])
}

model MessageConversationState {
  id         String    @id @default(cuid())
  userId     String
  partnerId  String
  isArchived Boolean   @default(false)
  mutedUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user    User @relation("ConversationStateUser", fields: [userId], references: [id], onDelete: Cascade)
  partner User @relation("ConversationStatePartner", fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([userId, partnerId])
  @@index([userId])
  @@index([partnerId])
}

enum NotificationType {
  NEW_COMMENT
  NEW_USER
  PENDING_CONTENT
  NEW_FILE
  CONTENT_PUBLISHED
  CONTENT_REJECTED
  CONTENT_REVISION_REQUESTED
  NEW_MESSAGE
  SYSTEM
}

model SiteSettings {
  id                       String   @id @default("default")
  siteName                 String   @default("TürkPDR")
  logoUrl                  String?
  faviconUrl               String?
  metaTitle                String?
  metaDescription          String?
  contactEmail             String?
  contactPhone             String?
  instagramUrl             String?
  twitterUrl               String?
  linkedinUrl              String?
  youtubeUrl               String?
  footerText               String?
  googleAnalyticsId        String?
  googleSearchConsoleCode  String?
  googleAdsensePublisherId String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model MediaAsset {
  id           String  @id @default(cuid())
  title        String?
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int
  category     String
  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([category])
  @@index([fileUrl])
  @@index([createdAt])
  @@index([deletedAt])
}

model ActivityLog {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action      String
  entityType  String
  entityId    String?
  description String

  metadata Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entityType])
  @@index([action])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  actionUrl String?
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

enum DictionaryStatus {
  DRAFT
  PUBLISHED
}

model DictionaryTerm {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  shortDescription String?
  content          String?
  category         String?
  status           DictionaryStatus @default(DRAFT)
  views            Int              @default(0)

  seoTitle       String?
  seoDescription String?
  ogImage        String?
  canonicalUrl   String?
  noIndex        Boolean @default(false)

  scheduledAt DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledAt])
  @@index([deletedAt])
}
